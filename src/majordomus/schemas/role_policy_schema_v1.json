{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_actions", "rules"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "default_actions": {
      "type": "array",
      "items": {"type": "string", "enum": ["VIEW", "EDIT", "TRANSITION"]}
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "pattern", "actions"],
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "pattern": {"type": "string", "minLength": 1},
          "actions": {
            "type": "array",
            "items": {"type": "string", "enum": ["VIEW", "EDIT", "TRANSITION"]}
          }
        }
      }
    }
  }
}
